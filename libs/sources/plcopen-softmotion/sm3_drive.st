(*
 * SM_Drive_GenericDS402 — generic CiA 402 (DS402) drive bridge.
 *
 * The OpenPLC analogue of CODESYS SM_Drive_ETC_GenericDSP402. One instance per
 * axis, called once per scan (generated by the editor at the top of the scan).
 * It is the ONLY block that copies the CiA 402 PDO image and converts between
 * increments and technical units. Data flow forms a one-scan pipeline:
 *   - copy this scan's drive TxPDO inputs  -> Axis.Drive + engineering feedback
 *   - copy last scan's MC_* command words  -> drive RxPDO outputs
 * The MC_* blocks run in between and act on Axis / Axis.Drive.
 *)
FUNCTION_BLOCK SM_Drive_GenericDS402
VAR_IN_OUT
	Axis : AXIS_REF_SM3;
END_VAR
VAR_INPUT
	(* from drive TxPDOs *)
	wStatusWord : UINT;                    (* 0x6041 *)
	siModesDisplay : SINT;                 (* 0x6061 *)
	diActualPosition : DINT;               (* 0x6064 *)
	diActualVelocity : DINT;               (* 0x606C *)
	iActualTorque : INT;                   (* 0x6077 *)
	bOnline : BOOL := TRUE;                (* fieldbus/slave operational *)
END_VAR
VAR_OUTPUT
	(* to drive RxPDOs *)
	wControlWord : UINT;                   (* 0x6040 *)
	siModes : SINT;                        (* 0x6060 *)
	diTargetPosition : DINT;               (* 0x607A *)
	udiProfileVelocity : UDINT;            (* 0x6081 *)
	diTargetVelocity : DINT;               (* 0x60FF *)
	iTargetTorque : INT;                   (* 0x6071 *)
END_VAR

(* ---- 1. Ingest drive feedback into the raw CiA 402 image ---- *)
Axis.Drive.StatusWord := wStatusWord;
Axis.Drive.Modes_of_operation_display := siModesDisplay;
Axis.Drive.Position_Actual_Value := diActualPosition;
Axis.Drive.Velocity_Actual_Value := diActualVelocity;
Axis.Drive.Torque_Actual_Value := iActualTorque;

(* ---- 2. Refresh the increments<->units scale factor ---- *)
IF Axis.dwRatioTechUnitsDenom = DWORD#0 THEN
	Axis.dwRatioTechUnitsDenom := DWORD#1;
END_IF
Axis.fIncPerUnit := Axis.fScalefactor
	* DINT_TO_LREAL(Axis.iRatioTechUnitsNum)
	/ DWORD_TO_LREAL(Axis.dwRatioTechUnitsDenom);
IF Axis.fIncPerUnit = 0.0 THEN
	Axis.fIncPerUnit := 1.0;
END_IF

(* ---- 3. Engineering-unit feedback ---- *)
Axis.fActPosition := DINT_TO_LREAL(Axis.Drive.Position_Actual_Value) / Axis.fIncPerUnit;
Axis.fActVelocity := DINT_TO_LREAL(Axis.Drive.Velocity_Actual_Value) / Axis.fIncPerUnit;
Axis.fActTorque := INT_TO_LREAL(Axis.Drive.Torque_Actual_Value);
Axis.byRealControllerMode := SINT_TO_BYTE(Axis.Drive.Modes_of_operation_display);

(* ---- 4. Communication + error + PLCopen state ---- *)
Axis.bCommunication := bOnline;
Axis.wCommunicationState := UINT_TO_WORD(Axis.Drive.StatusWord);
Axis.bRegulatorRealState := Axis.Drive.StatusWord.2;   (* Operation enabled *)
Axis.bDriveStartRealState := NOT Axis.Drive.StatusWord.5; (* NOT quick-stop-active *)
Axis.bError := Axis.Drive.StatusWord.3;                (* Fault *)

IF NOT bOnline THEN
	Axis.dwErrorID := DWORD#1;      (* SMC_DI_GENERAL_COMMUNICATION_ERROR *)
	Axis.nAxisState := SMC_AXIS_STATE.errorstop;
ELSIF Axis.bError THEN
	Axis.dwErrorID := DWORD#2;      (* SMC_DI_AXIS_ERROR *)
	Axis.nAxisState := SMC_AXIS_STATE.errorstop;
ELSE
	Axis.dwErrorID := DWORD#0;      (* SMC_NO_ERROR *)
	IF NOT Axis.Drive.StatusWord.2 THEN
		Axis.nAxisState := SMC_AXIS_STATE.power_off;        (* not operation-enabled *)
	ELSIF Axis.Drive.StatusWord.14 THEN
		Axis.nAxisState := SMC_AXIS_STATE.standstill;       (* SW bit14: standstill *)
	ELSIF Axis.Drive.Modes_of_operation_display = 3 THEN
		Axis.nAxisState := SMC_AXIS_STATE.continuous_motion;(* profile velocity *)
	ELSIF Axis.Drive.Modes_of_operation_display = 6 THEN
		Axis.nAxisState := SMC_AXIS_STATE.homing;
	ELSE
		Axis.nAxisState := SMC_AXIS_STATE.discrete_motion;
	END_IF
END_IF

(* ---- 5. Emit the RxPDO command image ---- *)
wControlWord := Axis.Drive.ControlWord;
siModes := Axis.Drive.Modes_of_operation;
diTargetPosition := Axis.Drive.Target_Position;
udiProfileVelocity := Axis.Drive.Profile_Velocity;
diTargetVelocity := Axis.Drive.Target_Velocity;
iTargetTorque := Axis.Drive.Target_torque;
END_FUNCTION_BLOCK
