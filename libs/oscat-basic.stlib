}\n    LIST_CLEAN_result = true;\n    return LIST_CLEAN_result;\n}\n\nIECStringVar<LIST_LENGTH> LIST_GET(IEC_BYTE SEP, IEC_INT POS, IEC_STRING& LIST) {\n    IECStringVar<LIST_LENGTH> LIST_GET_result;\n    IEC_INT I = 1;\n    IEC_INT O = 1;\n    IEC_Ptr<Array1D<IEC_BYTE, 1, 254>> PT;\n    IEC_Ptr<Array1D<IEC_BYTE, 1, 254>> PO;\n    IEC_INT CNT = 0;\n    IEC_BYTE C;\n    PT = &(LIST);\n    PO = &(LIST_GET_result);\n    do {\n        C = (*PT)[I];\n        if (CNT == POS) {\n            if (C == SEP) {\n                break;\n            }\n            (*PO)[O] = C;\n            O = O + 1;\n        } else if (C == SEP) {\n            CNT = CNT + 1;\n        }\n        I = I + 1;\n    } while (!((I == LIST_LENGTH) | (C == 0)));\n    (*PO)[O] = 0;\n    return LIST_GET_result;\n}\n\nIEC_BOOL LIST_INSERT(IEC_BYTE SEP, IEC_INT POS, IECStringVar<LIST_LENGTH> INS, IEC_STRING& LIST) {\n    IEC_BOOL LIST_INSERT_result;\n    IEC_Ptr<Array1D<IEC_BYTE, 1, 254>> PT;\n    IEC_INT READ = 1;\n    IEC_INT CNT = 1;\n    IECStringVar<1> SX;\n    PT = &(LIST);\n    if (LEN(INS) + 1 + LEN(LIST) > LIST_LENGTH) {\n        LIST_INSERT_result = false;\n    } else {\n        LIST_INSERT_result = true;\n        while (READ < LIST_LENGTH) {\n            if (CNT >= POS) {\n                SX = CHR_TO_STRING(SEP);\n                INS = CONCAT(SX, INS);\n                LIST = INSERT(LIST, INS, READ - 1);\n                LIST_INSERT_result = true;\n                return LIST_INSERT_result;\n            }\n            if ((*PT)[READ] == 0) {\n                (*PT)[READ] = SEP;\n                (*PT)[READ + 1] = 0;\n            }\n            READ = READ + 1;\n            if ((*PT)[READ] == SEP | (*PT)[READ] == 0) {\n                CNT = CNT + 1;\n            }\n        }\n    }\n    return LIST_INSERT_result;\n}\n\nIEC_INT LIST_LEN(IEC_BYTE SEP, IEC_STRING& LIST) {\n    IEC_INT LIST_LEN_result;\n    IEC_Ptr<Array1D<IEC_BYTE, 1, 254>> PT;\n    IEC_INT POS = 1;\n    IEC_BYTE C;\n    PT = &(LIST);\